# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.
# NONE of these are exposed to the browser (no VITE_ prefix) — they stay server-side.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Sender. Until you verify operatorstudio.ai in Resend, you MUST use the shared sender below.
# After verifying the domain, switch to e.g. "OperatorStudio <hello@operatorstudio.ai>".
CONTACT_FROM=OperatorStudio <onboarding@resend.dev>

# Where "Work with us" leads are delivered.
CONTACT_TO=eventsarbitrage@gmail.com

# Newsletter Audience id — Resend → Audiences → (your audience) → Settings.
RESEND_AUDIENCE_ID=
